    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@types/js-yaml": "^4.0.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "hash-wasm": "^4.12.0",
    "js-yaml": "^5.2.1",
    "jsqr": "^1.4.0",
    "lucide-react": "^0.556.0",
    "next": "^16.2.10",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.68.0",
    "react-syntax-highlighter": "^16.1.0",
    "resend": "^6.17.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-syntax-highlighter": "^15.5.13",
    "autoprefixer": "^10",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.0.7",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "postcss": "^8",
    "prettier": "^3.7.4",
    "tailwindcss": "^3",
    "typescript": "^5",
    "vitest": "^4.1.10",
    "yaml-loader": "^0.8.1"
