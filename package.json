{
  "name": "clash-chain-configurator",
  "version": "0.1.0",
  "private": true,
  "description": "本地优先、云端可选的 Mihomo/Clash Verge 链式代理配置器",
  "repository": {
    "type": "git",
    "url": "https://github.com/13967186047lee-maker/clash-chain-configurator.git"
  },
  "homepage": "https://jiakuan.didi4meme.win",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "prepare": "husky",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "security:audit": "npm audit --omit=dev --audit-level=high",
    "check": "npm run format:check && npm run lint && npm run test && npm run build && npm run security:audit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@node-rs/argon2": "^2.0.2",
